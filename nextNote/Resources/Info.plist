<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- User-visible app name. Keep this aligned with PRODUCT_NAME in project.yml
	     so Finder, Dock, and locally built bundles all appear as NextNote. -->
	<key>CFBundleDisplayName</key>
	<string>NextNote</string>
	<key>CFBundleName</key>
	<string>NextNote</string>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 NextAgentBC. Licensed under the Apache License 2.0.</string>
	<!-- ATS left at the default (HTTPS only). If you want to talk to a
	     local plain-HTTP LLM server (e.g. http://localhost:11434 for Ollama
	     or http://100.x.x.x on a Tailscale LAN), add an NSAppTransportSecurity
	     → NSExceptionDomains entry for that host. Example for Ollama:
	        <key>NSAppTransportSecurity</key>
	        <dict>
	          <key>NSExceptionDomains</key>
	          <dict>
	            <key>localhost</key>
	            <dict>
	              <key>NSExceptionAllowsInsecureHTTPLoads</key><true/>
	            </dict>
	          </dict>
	        </dict>
	     See docs/LLM_SETUP.md for details. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
