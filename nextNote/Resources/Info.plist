<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- User-visible app name. Keep this aligned with PRODUCT_NAME in project.yml
	     so Finder, Dock, and locally built bundles all appear as NextNote. -->
	<key>CFBundleDisplayName</key>
	<string>NextNote</string>
	<key>CFBundleName</key>
	<string>NextNote</string>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 NextAgentBC. Licensed under the PolyForm Noncommercial License 1.0.0. Commercial use requires a separate license.</string>
	<!-- AI provider endpoints commonly use plain HTTP on Tailscale tailnet
	     (100.64.0.0/10), localhost (Ollama), or a user-chosen custom host.
	     NSAllowsArbitraryLoads is broad but matches the BYO-endpoint design —
	     the user picks where their LLM lives. HTTPS endpoints (OpenAI,
	     Anthropic) still validate TLS certs normally. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
</dict>
</plist>
